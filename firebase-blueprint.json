{
  "entities": {
    "User": {
      "title": "User",
      "description": "Information about a registered user",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique user ID" },
        "name": { "type": "string", "description": "The display name of the user" },
        "email": { "type": "string", "format": "email", "description": "The email address of the user" },
        "avatar": { "type": "string", "description": "The avatar URL of the user" },
        "role": { "type": "string", "enum": ["customer", "rider", "ops"], "description": "The user role" }
      },
      "required": ["id", "name", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "An order placed by a customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "restaurantName": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["Delivered", "In Progress", "Cancelled"] },
        "totalAmount": { "type": "number" },
        "userId": { "type": "string" },
        "riderId": { "type": "string" }
      },
      "required": ["id", "restaurantName", "date", "status", "totalAmount", "userId"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Secure storage of registered users"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Customer order documents"
    }
  }
}
