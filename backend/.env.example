# ----- Server -----
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed origins for CORS (mobile uses *, web portals listed here)
CLIENT_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:19006

# ----- Database -----
# Local Mongo:    mongodb://127.0.0.1:27017/quickbite
# Atlas (cloud):  mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/quickbite
MONGODB_URI=mongodb://127.0.0.1:27017/quickbite

# ----- Auth / JWT -----
JWT_ACCESS_SECRET=change-me-to-a-long-random-string-access
JWT_REFRESH_SECRET=change-me-to-a-long-random-string-refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ----- OTP -----
# In dev, OTPs are NOT sent over SMS — they are returned in the API response and logged.
# Set OTP_DEV_MODE=false and wire an SMS provider (Twilio/MSG91) in prod.
OTP_DEV_MODE=true
OTP_TTL_SECONDS=300

# ----- Payments (mock gateway in dev) -----
PAYMENT_DEV_MODE=true

# ----- Pricing defaults (INR) -----
DEFAULT_DELIVERY_FEE=29
PACKAGING_FEE=10
TAX_RATE=0.05
PLATFORM_COMMISSION_RATE=0.15
